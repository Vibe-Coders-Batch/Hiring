# =====================================================================
# VaivammHire env — AWS-only path (Phase 1)
# =====================================================================
# Everything in this top section is AWS-native. The bootstrap script
# (`make setup`) populates these from CloudFormation outputs. You shouldn't
# need to edit them by hand.
# =====================================================================

# --- AWS ---
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=

# --- Postgres (Neon on Vercel, or local Docker / RDS) ---
# Neon: enable TLS — URL usually contains neon.tech (SSL auto-enabled in the app).
# Local Docker (docker compose / pnpm local): use the SAME URL here as when you run `pnpm db:seed`, or /jobs will show 0 roles.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vaivammhire

# --- AWS Bedrock (LLM) ---
# Verify availability at deploy time:
#   aws bedrock list-foundation-models --by-provider anthropic --region $AWS_REGION
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-v1:0
BEDROCK_FALLBACK_REGION=ap-southeast-1
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- S3 (resumes, offers, training data) ---
S3_RESUMES_BUCKET=vaivammhire-resumes-dev
S3_OFFERS_BUCKET=vaivammhire-offers-dev
S3_TRAINING_BUCKET=vaivammhire-training-dev

# --- Dev staff login (local / staging only — omit in production) ---
# Must match what you type as "Dev secret" on /admin/login. Min 16 characters.
# Seed creates admin@vaivammhire.local — use that email + this secret to sign in.
AUTH_DEV_SECRET=VaivammAdminDev2026!

# --- Cognito (admin + candidate auth) ---
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=
COGNITO_CANDIDATE_POOL_ID=
COGNITO_CANDIDATE_POOL_CLIENT_ID=

# --- AWS SES (transactional email) ---
SES_FROM_ADDRESS=hiring@vaivammcapital.com
SES_REPLY_TO=hr@vaivammcapital.com

# --- AWS SNS (interview reminders SMS) ---
SNS_TOPIC_REMINDERS_ARN=

# --- Track B ML inference (private API Gateway, deployed in Phase 2+) ---
ML_API_BASE_URL=
ML_API_FEATURE_FLAGS=m1=off,m2=off,m3=off,m4=on,m5=on

# --- App ---
# Production (AWS): set to the CloudFront URL from CDK output VaivammHire-Frontend-<env>.CloudFrontUrl
# Re-run `pnpm build:opennext` after the first deploy and set this to your https://xxx.cloudfront.net before rebuilding.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=VaivammHire

# =====================================================================
# DEFERRED — third-party integrations (NOT required for AWS-only path).
# Leave blank. The code branches no-op gracefully when these are empty.
# Re-enable one at a time when the relevant feature is needed.
# =====================================================================

# Google Calendar (interview scheduling)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# LinkedIn (one-click "Post to Vaivamm Page")
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Meta WhatsApp Cloud API
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_BUSINESS_TOKEN=

# Documenso e-signature (self-hosted on ECS Fargate, or DocuSign)
DOCUMENSO_API_KEY=
DOCUMENSO_BASE_URL=

# Cloudflare Turnstile captcha (AWS WAF rate-limiting handles bots in the
# meantime — see vaivammhire-infra/lib/frontend-stack.ts)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# CRM webhook (the receiving CRM is Vaivamm-internal, not part of this repo)
CRM_WEBHOOK_URL=
CRM_WEBHOOK_HMAC_SECRET=
