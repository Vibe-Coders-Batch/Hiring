# --- AWS ---
AWS_REGION=ap-south-1
AWS_ACCOUNT_ID=

# --- Database ---
# RDS Aurora Postgres Serverless v2 connection string. Use SSL in prod.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/vaivammhire

# --- Bedrock ---
# Verify model availability at deploy time:
# aws bedrock list-foundation-models --by-provider anthropic --region $AWS_REGION
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-v1:0
BEDROCK_FALLBACK_REGION=ap-southeast-1
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# --- S3 ---
S3_RESUMES_BUCKET=vaivammhire-resumes-dev
S3_OFFERS_BUCKET=vaivammhire-offers-dev
S3_TRAINING_BUCKET=vaivammhire-training-dev

# --- Cognito ---
COGNITO_USER_POOL_ID=
COGNITO_USER_POOL_CLIENT_ID=
COGNITO_CANDIDATE_POOL_ID=
COGNITO_CANDIDATE_POOL_CLIENT_ID=

# --- ML inference (Track B private API Gateway) ---
ML_API_BASE_URL=https://internal.ml.vaivammcapital.com/v1
ML_API_FEATURE_FLAGS=m1=shadow,m2=off,m3=off,m4=on,m5=on

# --- Comms ---
SES_FROM_ADDRESS=hiring@vaivammcapital.com
SES_REPLY_TO=hr@vaivammcapital.com
SNS_TOPIC_REMINDERS_ARN=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_BUSINESS_TOKEN=

# --- Integrations ---
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
DOCUMENSO_API_KEY=
DOCUMENSO_BASE_URL=https://documenso.vaivammcapital.com
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- CRM webhook ---
CRM_WEBHOOK_URL=https://crm.vaivammcapital.com/api/onboarding
CRM_WEBHOOK_HMAC_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BRAND_NAME=VaivammHire
